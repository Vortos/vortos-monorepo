APP_ENV=dev
APP_DEBUG=true

SERVER_NAME=:80
WORKER_NUM=4

DATABASE_URL=pgsql://postgres:12345@write_db:5432/squaura
POSTGRES_HOST=write_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345
POSTGRES_DB_NAME=squaura

MONGO_HOST=read_db
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=12345
MONGO_DB_NAME=squaura

REDIS_HOST=redis
REDIS_PORT=6379

MESSENGER_TRANSPORT_DSN=kafka://kafka:9092

KAFKA_BROKERS=kafka:9092

# producer transport DSN should follow 'MESSENGER_TRANSPORT_{ transport name }_PRODUCER_DSN' naming conventio
MESSENGER_TRANSPORT_ASYNC_PRODUCER_DSN=kafka://${KAFKA_BROKERS}
MESSENGER_TRANSPORT_EMAIL_PRODUCER_DSN=kafka://${KAFKA_BROKERS}

# consumer transport DSN should follow 'MESSENGER_TRANSPORT_{ transport name }_CONSUMER_DSN' naming convention
MESSENGER_TRANSPORT_ASYNC_CONSUMER_DSN=kafka://${KAFKA_BROKERS}
MESSENGER_TRANSPORT_EMAIL_CONSUMER_DSN=kafka://${KAFKA_BROKERS}