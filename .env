APP_ENV=dev
APP_DEBUG=true

POSTGRES_HOST=write_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345
POSTGRES_DB_NAME=squaura

MONGO_HOST=read_db
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=12345
MONGO_DB_NAME=squaura

REDIS_HOST=redis
REDIS_PORT=6379

# MESSENGER_TRANSPORT_DSN=kafka://kafka:9092

KAFKA_BROKERS=kafka:9092

# transport DNS should follow 'MESSENGER_TRANSPORT_{ transport name }_DSN' naming convention
MESSENGER_TRANSPORT_ASYNC_DSN=kafka://${KAFKA_BROKERS}
MESSENGER_TRANSPORT_EMAIL_DSN=kafka://${KAFKA_BROKERS}