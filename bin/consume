# !/usr/bin/env php
<?php

$config = require __DIR__ . '/../bootstrap/app.php';

use Fortizan\Tekton\Foundation\Runner;

$groupId = $argv[1] ?? throw new InvalidArgumentException("Missing group_id");

$runner = new Runner(...$config, context: 'console');

$container = $runner->setParameter('messenger.consumer.async.group_id', $groupId)
    ->withRoutes(true)
    ->getContainer();

$container->get('tekton.consumer')->run();

$runner->cleanUp();
