{
  "name": "fortizan/squaura",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "./packages/Tekton",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "fortizan/tekton": "@dev"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  }
}
