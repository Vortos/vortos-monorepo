{
  "name": "fortizan/squaura",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "./packages/Vortos",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "./packages/Vortos/src/Make",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "vortos/vortos": "@dev",
    "doctrine/orm": "^3.5",
    "doctrine/dbal": "^4.4",
    "symfony/cache": "^8.0",
    "symfony/var-exporter": "^7.0",
    "doctrine/migrations": "^3.9",
    "mongodb/mongodb": "^2.1",
    "symfony/uid": "^8.0",
    "koco/messenger-kafka": "^0.18.0",
    "symfony/amqp-messenger": "^8.0",
    "symfony/redis-messenger": "^8.0",
    "symfony/doctrine-messenger": "^8.0",
    "symfony/serializer": "^8.0",
    "symfony/property-access": "^8.0",
    "psr/simple-cache": "^3.0",
    "firebase/php-jwt": "^7.0",
    "symfony/validator": "^7.0"
  },
  "require-dev": {
    "vortos/vortos-make": "@dev",
    "phpunit/phpunit": "^11.0",
    "kwn/php-rdkafka-stubs": "^2.0",
    "open-telemetry/api": "^1.8",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "App\\Migrations\\": "migrations/",
      "Vortos\\Migration\\": "packages/Vortos/src/Migration/",
      "Vortos\\Debug\\": "packages/Vortos/src/Debug/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Vortos\\Tests\\": "packages/Vortos/Tests/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "php tools/link-packages.php"
    ],
    "post-update-cmd": [
      "php tools/link-packages.php"
    ]
  }
}
