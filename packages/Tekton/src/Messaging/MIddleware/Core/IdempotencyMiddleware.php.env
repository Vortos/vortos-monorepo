<?php

declare(strict_types=1);

namespace Fortizan\Tekton\Messaging\Middleware\Core;

use Fortizan\Tekton\Messaging\Bus\Stamp\ConsumerStamp;
use Fortizan\Tekton\Messaging\Bus\Stamp\EventIdStamp;
use Fortizan\Tekton\Messaging\Middleware\MiddlewareInterface;
use Fortizan\Tekton\Messaging\Registry\HandlerRegistry;
use Psr\SimpleCache\CacheInterface;
use Symfony\Component\Messenger\Envelope;

/**
 * Prevents duplicate processing of the same event by caching processed event IDs.
 * Uses EventIdStamp as the deduplication key. If the event has already been
 * processed and the handler is not marked idempotent, the envelope is returned
 * without invoking the next middleware or handler.
 * TTL defaults to 24 hours. Requires a PSR-16 cache implementation.
 * 
 * @Note :  HandlerStamp is not yet present when this middleware runs (handler hasn't
 * executed). The idempotent check currently always applies. Future improvement:
 * inject HandlerRegistry and check the descriptor directly.
 */
final class IdempotencyMiddleware implements MiddlewareInterface
{
    public function __construct(
        private CacheInterface $cache,
        private HandlerRegistry $handlerRegistry,
        private int $ttlSeconds = 86400
    ){
    }

    public function handle(Envelope $envelope, callable $next): Envelope
    {
        $eventIdStamp = $envelope->last(EventIdStamp::class);
        
        if($eventIdStamp === null){
            return $next($envelope);
        }

        $cacheKey = 'tekton_idempotency_' . $eventIdStamp->eventId;

        $consumerStamp = $envelope->last(ConsumerStamp::class);

        if ($consumerStamp === null) {
            return $next($envelope);
        }

        $consumerName = $consumerStamp->consumerName;
        $eventClass = get_class($envelope->getMessage());

        $descriptors = $this->handlerRegistry->getHandlers($consumerName, $eventClass);

        $allIdempotent = !empty($descriptors) && array_reduce(
            $descriptors,
            fn (bool $carry, array $d) => $carry && $d['idempotent'], 
            true
        );

        $alreadyProcessed = $this->cache->has($cacheKey);

        if($alreadyProcessed && !$allIdempotent){
            return $envelope;
        }

        $result = $next($envelope);

        $this->cache->set($cacheKey, true, $this->ttlSeconds);

        return $result;
    }
}