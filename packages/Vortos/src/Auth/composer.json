{
    "name": "vortos/vortos-auth",
    "description": "Vortos authentication \u2014 JWT, Argon2id, token rotation, built-in controllers",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Vortos\\Auth\\": ""
        }
    },
    "require": {
        "php": ">=8.2",
        "vortos/vortos-domain": "^1.0",
        "vortos/vortos-cache": "^1.0",
        "vortos/vortos-http": "^1.0",
        "symfony/http-kernel": "^7.3",
        "firebase/php-jwt": "^7.0"
    },
    "extra": {
        "vortos": {
            "package": "Vortos\\Auth\\DependencyInjection\\AuthPackage",
            "order": 100
        }
    }
}