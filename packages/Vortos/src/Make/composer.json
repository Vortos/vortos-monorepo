{
    "name": "vortos/vortos-make",
    "description": "Vortos code generator — scaffold DDD/CQRS artifacts from stubs",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Vortos\\Make\\": ""
        }
    },
    "require": {
        "php": ">=8.2",
        "vortos/vortos-foundation": "^1.0",
        "symfony/console": "^7.0"
    },
    "extra": {
        "vortos": {
            "package": "Vortos\\Make\\DependencyInjection\\MakePackage",
            "order": 200
        }
    }
}
